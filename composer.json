{
    "name": "teariot/json-repair",
    "description": "Repair broken, malformed, or non-standard JSON — fix quotes, commas, comments, Python constants, JSONP, NDJSON, HTML entities, and more",
    "type": "library",
    "keywords": [
        "json",
        "repair",
        "fix",
        "parse",
        "invalid",
        "malformed",
        "broken",
        "streaming",
        "ndjson",
        "jsonp",
        "comments",
        "python",
        "mongodb"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Teariot",
            "email": "teaRiot@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-mbstring": "*",
      "ext-ctype": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "Teariot\\JsonRepair\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Teariot\\JsonRepair\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0-dev"
        }
    },
    "minimum-stability": "stable"
}
